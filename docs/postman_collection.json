    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseJson = pm.response.json();",
              "if (responseJson.success && responseJson.data) {",
              "    pm.environment.set(\"access_token\", responseJson.data.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jane.doe@locallens.ai\",\n  \"password\": \"securepassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "auth",
            "login"
          ]
        },
        "description": "Authenticate user credentials and receive access tokens."
      },
      "response": []
    },
