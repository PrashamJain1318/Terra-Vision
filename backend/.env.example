# LocalLens AI Backend Environment Variables

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/locallens-ai?retryWrites=true&w=majority
JWT_SECRET=your_jwt_signing_secret_key_minimum_32_characters
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret
